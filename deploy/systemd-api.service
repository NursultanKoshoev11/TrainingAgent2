[Unit]
Description=Crypto AI Advisor API
After=network.target

[Service]
WorkingDirectory=/opt/crypto-ai-advisor/backend
EnvironmentFile=/opt/crypto-ai-advisor/.env
ExecStart=/usr/bin/python -m uvicorn app.server:server --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
