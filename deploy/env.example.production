APP_NAME=Crypto AI Advisor
API_HOST=0.0.0.0
API_PORT=8000
DEFAULT_EXCHANGE=binance
DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT
DEFAULT_TIMEFRAME=1h
DEFAULT_NEWS_LIMIT=12
USE_CCXT=true
CRYPTOPANIC_API_KEY=
SENTIMENT_MODEL_URL=
GDELT_ENABLED=false
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_ai_advisor
ADVISOR_DB_PATH=advisor_data.sqlite3
STREAMING_ENABLED=true
STREAMING_PROVIDER=cryptofeed
STREAM_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
STREAM_POLL_INTERVAL_SECONDS=10
SCHEDULER_MODE=manual-worker
MARKET_INTERVAL_SECONDS=300
NEWS_INTERVAL_SECONDS=300
OVERVIEW_INTERVAL_SECONDS=900
SAVE_SCHEDULED_SIGNALS=true
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE=http://localhost:8000
