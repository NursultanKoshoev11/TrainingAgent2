APP_NAME=Crypto AI Advisor
API_HOST=0.0.0.0
API_PORT=8000
DEFAULT_EXCHANGE=binance
DEFAULT_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
DEFAULT_TIMEFRAME=1h
DEFAULT_NEWS_LIMIT=12
USE_CCXT=false
CRYPTOPANIC_API_KEY=
SENTIMENT_MODEL_URL=
